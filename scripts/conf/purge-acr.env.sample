ACR_REGISTRY=example.azurecr.io

# Each entry maps a repository to one or more ERE regex patterns (comma-separated).
# A tag is RETAINED if it matches ANY pattern; all other tags are deleted.
REPOSITORY_TAG_PATTERNS=(
    frontend-repo/sample-webui:"*\.target01\.*,*\.target02\.*"
    backend-repo/sample-api:"*-dev\.all\.*,*-uat\.all\.*"
    backend-repo/sample-worker:"*-dev\.all\.*,*-uat\.all\.*"
)

# These exact repo:tag references are never deleted, regardless of patterns above.
ALWAYS_RETAIN_IMAGES=(
    frontend-repo/sample-webui:2.2.0-uat.target01
    frontend-repo/sample-webui:2.2.1-prd.target02
)
