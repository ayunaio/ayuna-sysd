COMPOSE_PROJECT_NAME=ayunasrv

## PostgreSQL specific environment
TZ=UTC
PGTZ=UTC
POSTGRES_HOST=ayuna-postgres
POSTGRES_PORT=5432
POSTGRES_USER=ayunauser
POSTGRES_PASSWORD={{ store.postgres.password }}
POSTGRES_AYUNA_DB=ayuna_db

## Neo4j specific environment
NEO4J_URI=bolt://ayuna-neo4j:7687
NEO4J_AUTH=neo4j/{{ store.neo4j.password }}
NEO4J_DATABASE=neo4j
NEO4J_PLUGINS='["apoc"]'

## Redis / ValKey specific environment
REDIS_HOST="ayuna-valkey"
REDIS_PORT=6379
REDIS_AUTH={{ store.valkey.password }}
VALKEY_PASSWORD={{ store.valkey.password }}

## NATS-JS configuration
NATS_AUTH_ADMIN_PASSWORD={{ nats.admin.password }}
NATS_AUTH_ISSUER_PUB={{ nats.auth_callout.issuer_pub }}
NATS_AUTH_ISSUER_SEED={{ nats.auth_callout.issuer_seed }}

## SeaweedFS / S3 specific environment
ADMIN_S3_ACCESS_KEY={{ store.s3.admin.access_key }}
ADMIN_S3_SECRET_KEY={{ store.s3.admin.secret_key }}
