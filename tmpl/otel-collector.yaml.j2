---
extensions:
  health_check:
    endpoint: 0.0.0.0:13133
  pprof:
    endpoint: 0.0.0.0:1888
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
  otlp:
    protocols:
      http:
        endpoint: "0.0.0.0:4318"
      grpc:
        endpoint: "0.0.0.0:4317"

processors:
  batch:
    timeout: 5s
    send_batch_size: 100
    send_batch_max_size: 1000

exporters:
  otlp_http/openobserve:
    endpoint: http://ayuna-open-observe:5080/api/default
    headers:
      Authorization: {{ otel.auth_header | tojson }}
      stream-name: default
  otlp/openobserve:
    endpoint: http://ayuna-open-observe:5081
    headers:
      Authorization: {{ otel.auth_header | tojson }}
      organization: default
      stream-name: default
    tls:
      insecure: true

service:
  extensions: [health_check, pprof, zpages]
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [otlp_http/openobserve] # Use `otlp` for gRPC
    metrics:
      receivers: [otlp]
      processors: [batch]
      exporters: [otlp_http/openobserve]
    logs:
      receivers: [otlp]
      processors: [batch]
      exporters: [otlp_http/openobserve]
